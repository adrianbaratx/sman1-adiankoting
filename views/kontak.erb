<% @title = "Kontak - SMA Negeri 1 Adiankoting" %>

<section class="page-hero">
  <div class="container">
    <span class="eyebrow light">Kontak Sekolah</span>
    <h2>Hubungi SMA Negeri 1 Adiankoting</h2>
    <p>Silakan hubungi sekolah untuk informasi akademik, administrasi, penerimaan peserta didik baru, dan layanan lainnya.</p>
  </div>
</section>

<section class="section contact-section">
  <div class="container contact-grid">
    <div class="contact-info">
      <span class="eyebrow">Informasi Kontak</span>
      <h2>Alamat dan Layanan Sekolah</h2>
      <p>Gunakan informasi kontak berikut untuk menghubungi pihak sekolah pada jam layanan.</p>
      <div class="contact-list">
        <div><strong>Alamat</strong><span>Adiankoting, Kabupaten Tapanuli Utara, Sumatera Utara</span></div>
        <div><strong>Email</strong><span>info@sman1adiankoting.sch.id</span></div>
        <div><strong>Telepon</strong><span>0000-0000-0000</span></div>
        <div><strong>Jam Layanan</strong><span>Senin - Jumat, 08.00 - 15.00 WIB</span></div>
      </div>
    </div>
    <div class="contact-form-card">
      <h3>Kirim Pesan</h3>
      <% if @success %><div class="alert-success">Terima kasih, <%= @nama %>. Pesan berhasil disiapkan.</div><% end %>
      <form action="/kontak" method="post">
        <label>Nama Lengkap</label><input type="text" name="nama" placeholder="Masukkan nama lengkap" required>
        <label>Email</label><input type="email" name="email" placeholder="Masukkan email" required>
        <label>Pesan</label><textarea name="pesan" rows="6" placeholder="Tulis pesan Anda" required></textarea>
        <button type="submit" class="btn primary">Kirim Pesan</button>
      </form>
    </div>
  </div>
</section>
