<section class="page-hero">
  <div class="container page-hero-inner reveal">
    <span class="eyebrow light">Kontak Sekolah</span>
    <h1>Hubungi SMA Negeri 1 Adiankoting</h1>
    <p>Silakan hubungi sekolah untuk informasi akademik, administrasi, PPDB, dan layanan lainnya.</p>
  </div>
</section>

<section class="section-pad">
  <div class="container split-grid">
    <div class="content-panel reveal"><span class="eyebrow">Informasi Kontak</span><h2>Kontak Resmi Sekolah</h2><div class="notice-item"><b>Alamat</b><span><%= @sekolah[:alamat] %></span></div><div class="notice-item"><b>Email</b><span><%= @sekolah[:email] %></span></div><div class="notice-item"><b>Telepon</b><span><%= @sekolah[:telepon] %></span></div><div class="notice-item"><b>Jam Layanan</b><span><%= @sekolah[:jam] %></span></div></div>
    <div class="contact-form-card reveal"><h3>Kirim Pesan</h3><form><label>Nama Lengkap</label><input type="text" placeholder="Masukkan nama lengkap"><label>Email</label><input type="email" placeholder="Masukkan email"><label>Pesan</label><textarea rows="6" placeholder="Tulis pesan Anda"></textarea><button class="btn btn-primary" type="submit">Kirim Pesan</button></form></div>
  </div>
</section>
