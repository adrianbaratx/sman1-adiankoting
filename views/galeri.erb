<section class="page-hero">
  <div class="container page-hero-inner reveal">
    <span class="eyebrow light">Galeri Sekolah</span>
    <h1>Dokumentasi Kegiatan</h1>
    <p>Dokumentasi suasana belajar dan kegiatan siswa di SMA Negeri 1 Adiankoting.</p>
  </div>
</section>

<section class="section-pad">
  <div class="container gallery-grid">
    <% @galeri.each do |item| %>
      <figure class="gallery-card reveal"><img src="<%= item[:gambar] %>" alt="<%= item[:judul] %>"><figcaption><%= item[:judul] %></figcaption></figure>
    <% end %>
  </div>
</section>
