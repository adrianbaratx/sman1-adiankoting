<section class="page-hero">
  <div class="container page-hero-inner reveal">
    <span class="eyebrow light">Berita & Pengumuman</span>
    <h1>Informasi Terbaru Sekolah</h1>
    <p>Kegiatan, prestasi, pengumuman, dan agenda terbaru SMA Negeri 1 Adiankoting.</p>
  </div>
</section>

<section class="section-pad">
  <div class="container section-title reveal"><span class="eyebrow">Kabar Sekolah</span><h2>Berita dan Pengumuman</h2><p>Gunakan kolom pencarian untuk mencari berita berdasarkan judul atau kategori.</p></div>
  <div class="container search-wrap reveal"><input id="searchBerita" type="search" placeholder="Cari berita atau pengumuman..."></div>
  <div class="container news-grid" id="newsGrid">
    <% @berita.each do |item| %>
      <%= component :_news_card, item: item %>
    <% end %>
  </div>
</section>
